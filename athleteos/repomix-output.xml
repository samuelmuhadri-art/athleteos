import { memo, useState, useMemo, useCallback, useEffect } from "react";
import {
  ChevronLeft, ChevronRight, Plus, X,
  Clock, Users, FileText, AlertCircle,
  CheckCircle, AlertTriangle, XCircle, CalendarDays,
  Star, Zap,
} from "lucide-react";
