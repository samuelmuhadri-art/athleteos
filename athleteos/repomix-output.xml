                  { key: "forme",        label: "Forme",           value: metrics.forme,        inv: false },
                  { key: "fatigue",      label: "Fatigue",         value: metrics.fatigue,      inv: true  },
                  { key: "recuperation", label: "Récupération",    value: metrics.recuperation, inv: false },
